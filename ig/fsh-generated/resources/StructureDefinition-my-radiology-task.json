{
  "resourceType": "StructureDefinition",
  "id": "my-radiology-task",
  "url": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-task",
  "name": "MYRadiologyTask",
  "title": "MY Radiology Task",
  "status": "draft",
  "experimental": false,
  "description": "Workflow tracking profile used to communicate radiology order receipt, acceptance, scheduling, in-progress, completion, rejection, cancellation, amendment, and report publication states.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Task",
  "baseDefinition": "http://fhir.hie.moh.gov.my/StructureDefinition/Task-my-core",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Task",
        "path": "Task",
        "constraint": [
          {
            "key": "my-radiology-task-completed-requires-output",
            "human": "A completed workflow task shall expose at least one output reference.",
            "source": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-task",
            "severity": "error",
            "expression": "status = 'completed' implies output.exists()"
          }
        ]
      },
      {
        "id": "Task.identifier",
        "path": "Task.identifier",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "system"
            }
          ],
          "rules": "open"
        },
        "min": 1
      },
      {
        "id": "Task.identifier:workflowTask",
        "path": "Task.identifier",
        "sliceName": "workflowTask",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Task.identifier:workflowTask.type.text",
        "path": "Task.identifier.type.text",
        "patternString": "Radiology workflow task identifier"
      },
      {
        "id": "Task.identifier:workflowTask.system",
        "path": "Task.identifier.system",
        "min": 1,
        "fixedUri": "https://sandbox.myehr.kkmhub.moh.gov.my/id/radiology-task"
      },
      {
        "id": "Task.identifier:workflowTask.value",
        "path": "Task.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Task.basedOn",
        "path": "Task.basedOn",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-service-request"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Task.status",
        "path": "Task.status",
        "mustSupport": true
      },
      {
        "id": "Task.statusReason",
        "path": "Task.statusReason",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/ValueSet/my-radiology-task-status-reason-vs"
        }
      },
      {
        "id": "Task.businessStatus",
        "path": "Task.businessStatus",
        "short": "Use the required MY Core business-status vocabulary; radiology workflow states are refined in national narrative guidance",
        "mustSupport": true
      },
      {
        "id": "Task.intent",
        "path": "Task.intent",
        "patternCode": "order"
      },
      {
        "id": "Task.code",
        "path": "Task.code",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Task.code.text",
        "path": "Task.code.text",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Task.focus",
        "path": "Task.focus",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-service-request"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Task.for",
        "path": "Task.for",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Task.encounter",
        "path": "Task.encounter",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://fhir.hie.moh.gov.my/StructureDefinition/Encounter-my-core"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Task.authoredOn",
        "path": "Task.authoredOn",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Task.lastModified",
        "path": "Task.lastModified",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Task.owner",
        "path": "Task.owner",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://fhir.hie.moh.gov.my/StructureDefinition/Organization-my-core"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Task.note",
        "path": "Task.note",
        "mustSupport": true
      },
      {
        "id": "Task.input",
        "path": "Task.input",
        "mustSupport": true
      },
      {
        "id": "Task.output",
        "path": "Task.output",
        "mustSupport": true
      },
      {
        "id": "Task.output.type",
        "path": "Task.output.type",
        "mustSupport": true
      },
      {
        "id": "Task.output.type.text",
        "path": "Task.output.type.text",
        "min": 1,
        "patternString": "report",
        "mustSupport": true
      },
      {
        "id": "Task.output.value[x]",
        "path": "Task.output.value[x]",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-diagnostic-report"
            ]
          }
        ],
        "mustSupport": true
      }
    ]
  }
}
