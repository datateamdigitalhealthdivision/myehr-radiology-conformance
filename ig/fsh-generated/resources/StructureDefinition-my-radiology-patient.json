{
  "resourceType": "StructureDefinition",
  "id": "my-radiology-patient",
  "url": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-patient",
  "name": "MYRadiologyPatient",
  "title": "MY Radiology Patient",
  "status": "draft",
  "experimental": false,
  "description": "Radiology-layer patient profile derived from MY Core. It fixes the minimum identifier scaffolding required across the national radiology use cases, including national civil identity, a nationally reserved placeholder namespace for local patient registration, and the PROVISIONAL MyHRN slice that implementation partners should support now for future activation without code change.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Patient",
  "baseDefinition": "http://fhir.myehr.kkmhub.moh.gov.my/StructureDefinition/Patient-my-core",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Patient.identifier",
        "path": "Patient.identifier",
        "min": 2
      },
      {
        "id": "Patient.identifier:nationalId",
        "path": "Patient.identifier",
        "sliceName": "nationalId",
        "short": "National identity card number (MyKad, MyKAS, or passport)",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:nationalId.type",
        "path": "Patient.identifier.type",
        "patternCodeableConcept": {
          "coding": [
            {
              "code": "NIIP",
              "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
              "display": "National unique individual identifier"
            }
          ]
        }
      },
      {
        "id": "Patient.identifier:nationalId.system",
        "path": "Patient.identifier.system",
        "min": 1,
        "fixedUri": "http://fhir.myehr.kkmhub.moh.gov.my/sid/my-kad"
      },
      {
        "id": "Patient.identifier:nationalId.value",
        "path": "Patient.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:localPatientId",
        "path": "Patient.identifier",
        "sliceName": "localPatientId",
        "short": "Site-local patient registration number carried in the nationally reserved local patient identifier namespace",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:localPatientId.type",
        "path": "Patient.identifier.type",
        "patternCodeableConcept": {
          "coding": [
            {
              "code": "MR",
              "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
              "display": "Medical record number"
            }
          ]
        }
      },
      {
        "id": "Patient.identifier:localPatientId.system",
        "path": "Patient.identifier.system",
        "min": 1,
        "fixedUri": "http://fhir.myehr.kkmhub.moh.gov.my/sid/local-patient-id"
      },
      {
        "id": "Patient.identifier:localPatientId.value",
        "path": "Patient.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:myHrn",
        "path": "Patient.identifier",
        "sliceName": "myHrn",
        "short": "National Master Patient Index identifier (MyHRN). Pending national MPI activation.",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Patient.identifier:myHrn.type.text",
        "path": "Patient.identifier.type.text",
        "patternString": "MyHRN"
      },
      {
        "id": "Patient.identifier:myHrn.system",
        "path": "Patient.identifier.system",
        "min": 1,
        "fixedUri": "http://fhir.myehr.kkmhub.moh.gov.my/sid/my-hrn"
      },
      {
        "id": "Patient.identifier:myHrn.value",
        "path": "Patient.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Patient.name",
        "path": "Patient.name",
        "mustSupport": true
      },
      {
        "id": "Patient.gender",
        "path": "Patient.gender",
        "mustSupport": true
      },
      {
        "id": "Patient.birthDate",
        "path": "Patient.birthDate",
        "mustSupport": true
      }
    ]
  }
}
