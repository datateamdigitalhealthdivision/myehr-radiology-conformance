{
  "resourceType": "StructureDefinition",
  "id": "my-radiology-service-request",
  "url": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-service-request",
  "name": "MYRadiologyServiceRequest",
  "title": "MY Radiology ServiceRequest",
  "status": "draft",
  "experimental": false,
  "description": "Radiology imaging order profile for Malaysian deployments. It captures requested procedure, priority, indication, requester context, patient linkage, location, and provisional accession handling.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "ServiceRequest",
  "baseDefinition": "http://fhir.hie.moh.gov.my/StructureDefinition/ServiceRequest-my-core",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "ServiceRequest",
        "path": "ServiceRequest",
        "constraint": [
          {
            "key": "my-radiology-servicerequest-order-intent",
            "human": "ServiceRequest.intent shall be order for this implementation guide.",
            "source": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-service-request",
            "severity": "error",
            "expression": "intent = 'order'"
          },
          {
            "key": "my-radiology-servicerequest-category-imaging",
            "human": "A radiology ServiceRequest shall declare an imaging or radiology category code.",
            "source": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/StructureDefinition/my-radiology-service-request",
            "severity": "error",
            "expression": "category.coding.where((system = 'http://terminology.hl7.org/CodeSystem/v2-0074' and code = 'RAD') or (system = 'http://snomed.info/sct' and code = '363679005')).exists()"
          }
        ]
      },
      {
        "id": "ServiceRequest.identifier",
        "path": "ServiceRequest.identifier",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "system"
            }
          ],
          "rules": "open"
        },
        "min": 1
      },
      {
        "id": "ServiceRequest.identifier:placerOrder",
        "path": "ServiceRequest.identifier",
        "sliceName": "placerOrder",
        "short": "Business order identifier issued by the order placer",
        "min": 1,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.identifier:placerOrder.type",
        "path": "ServiceRequest.identifier.type",
        "patternCodeableConcept": {
          "coding": [
            {
              "code": "PLAC",
              "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
              "display": "Placer Identifier"
            }
          ]
        }
      },
      {
        "id": "ServiceRequest.identifier:placerOrder.system",
        "path": "ServiceRequest.identifier.system",
        "min": 1,
        "fixedUri": "https://sandbox.myehr.kkmhub.moh.gov.my/id/radiology-order"
      },
      {
        "id": "ServiceRequest.identifier:placerOrder.value",
        "path": "ServiceRequest.identifier.value",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.identifier:accession",
        "path": "ServiceRequest.identifier",
        "sliceName": "accession",
        "short": "Accession identifier within the nationally reserved accession namespace",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.identifier:accession.type",
        "path": "ServiceRequest.identifier.type",
        "patternCodeableConcept": {
          "coding": [
            {
              "code": "ACSN",
              "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
              "display": "Accession ID"
            }
          ]
        }
      },
      {
        "id": "ServiceRequest.identifier:accession.system",
        "path": "ServiceRequest.identifier.system",
        "min": 1,
        "fixedUri": "https://id.kkmhub.moh.gov.my/accession"
      },
      {
        "id": "ServiceRequest.identifier:accession.value",
        "path": "ServiceRequest.identifier.value",
        "short": "Facility-traceable accession value, for example FACILITYCODE-YYYYMMDD-SEQUENCE",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.status",
        "path": "ServiceRequest.status",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.intent",
        "path": "ServiceRequest.intent",
        "patternCode": "order"
      },
      {
        "id": "ServiceRequest.category",
        "path": "ServiceRequest.category",
        "short": "Order category shall identify imaging or radiology for reliable workflow routing and filtering",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.priority",
        "path": "ServiceRequest.priority",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.code",
        "path": "ServiceRequest.code",
        "short": "Use the national imaging procedure catalogue. Starter LOINC support is retained for direct-RIS retrieval implementations.",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/ValueSet/my-radiology-procedure-code-vs"
        }
      },
      {
        "id": "ServiceRequest.subject",
        "path": "ServiceRequest.subject",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://fhir.hie.moh.gov.my/StructureDefinition/Patient-my-core"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.encounter",
        "path": "ServiceRequest.encounter",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://fhir.hie.moh.gov.my/StructureDefinition/Encounter-my-core"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.occurrence[x]",
        "path": "ServiceRequest.occurrence[x]",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.authoredOn",
        "path": "ServiceRequest.authoredOn",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.requester",
        "path": "ServiceRequest.requester",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://fhir.hie.moh.gov.my/StructureDefinition/PractitionerRole-my-core"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.locationReference",
        "path": "ServiceRequest.locationReference",
        "short": "Requested radiology location, department, or performance site where known",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://fhir.hie.moh.gov.my/StructureDefinition/Location-my-core"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.reasonCode",
        "path": "ServiceRequest.reasonCode",
        "short": "Clinical indication, diagnosis, or appropriateness context for the requested examination",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "https://myehr.kkmhub.moh.gov.my/fhir/ImplementationGuide/my-radiology/ValueSet/my-radiology-clinical-indication-vs"
        }
      },
      {
        "id": "ServiceRequest.supportingInfo",
        "path": "ServiceRequest.supportingInfo",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.bodySite",
        "path": "ServiceRequest.bodySite",
        "short": "Use SNOMED CT body structures and include laterality where clinically relevant",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.bodySite:side",
        "path": "ServiceRequest.bodySite",
        "sliceName": "side",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.bodySite:site",
        "path": "ServiceRequest.bodySite",
        "sliceName": "site",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.note",
        "path": "ServiceRequest.note",
        "mustSupport": true
      }
    ]
  }
}
