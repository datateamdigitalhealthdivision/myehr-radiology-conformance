  "format": [
    "json",
    "xml"
  ],
  "description": "Server capability expectations for the MHD-to-XDS gateway or FHIR document registry that receives radiology document submissions and responds to document-discovery queries.",
  "rest": [
    {
      "mode": "server",
      "interaction": [
        {
          "code": "transaction",
          "documentation": "The Document Recipient SHALL accept ITI-65 transaction Bundles containing a SubmissionSet List, one or more DocumentReferences, and optional Binary resources, validate the metadata, and return a transaction-response."
        }
      ],
      "resource": [
        {
          "type": "DocumentReference",
